#!/usr/bin/env node
"use strict";

var { Command } = require("commander");
var { run, watch } = require("@assetpipe/core/runtime");

var program = new Command();

program
  .name("assetpipe")
  .description("CLI to execute AssetPipe's pipelines")
  .version("1.0.0")
  .option("-w, --watch", "Watch mode", false)
  .option("-c, --cache <PATH>", "Cache directory")
  .option("-o, --output <PATH>", "Output directory", "out")
  .argument("<PIPELINE_PATH>");

program.parse();

var [PIPELINE_PATH] = program.args;
var options = program.opts();

async function main() {
  if (options.watch) {
    const watcher = await watch({
      entry: PIPELINE_PATH,
      outputDirectory: options.output,
      cacheDirectory: options.cache,
    });

    await watcher.spawn();
  } else {
    await run({
      entry: PIPELINE_PATH,
      outputDirectory: options.output,
      cacheDirectory: options.cache,
    });
  }
}

main();
