{
  "name": "@assetpipe/image",
  "version": "0.5.2",
  "author": "",
  "license": "Apache-2.0",
  "description": "Image-processing transformers for AssetPipe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koteelok/assetpipe.git",
    "directory": "packages/image"
  },
  "main": "./dist/exports.js",
  "module": "./dist/exports.mjs",
  "types": "./dist/exports.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/exports.d.mts",
        "default": "./dist/exports.mjs"
      },
      "require": {
        "types": "./dist/exports.d.ts",
        "default": "./dist/exports.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@assetpipe/core": "^0.5.2",
    "@assetpipe/config": "^0.5.2",
    "maxrects-packer": "2.7.3",
    "sharp": "0.33.3"
  },
  "devDependencies": {
    "tsdown": "^0.15.6"
  },
  "nx": {
    "name": "image",
    "targets": {
      "build": {
        "inputs": [
          "{projectRoot}/**/*.ts"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  }
}
