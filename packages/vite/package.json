{
  "name": "@assetpipe/vite",
  "version": "0.8.0",
  "author": "",
  "license": "Apache-2.0",
  "description": "Vite integration for AssetPipe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koteelok/assetpipe.git",
    "directory": "packages/vite"
  },
  "main": "./dist/exports.js",
  "module": "./dist/exports.mjs",
  "types": "./dist/exports.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/exports.d.mts",
        "default": "./dist/exports.mjs"
      },
      "require": {
        "types": "./dist/exports.d.ts",
        "default": "./dist/exports.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@assetpipe/core": "^0.8.0",
    "@types/picomatch": "^4.0.2",
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.107.0",
    "picomatch": "^4.0.3",
    "sirv": "^3.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.15.6"
  },
  "peerDependencies": {
    "vite": ">=7"
  }
}
